#!/usr/bin/env bash

folder="$HOME/notes/"

TERMINAL=${TERMINAL:-foot}

rofi_cmd="rofi -dmenu -i -p"

newnote () {
  dir="$(command ls -d "$folder" "$folder"*/ 2>/dev/null | $rofi_cmd 'Choose directory')" || exit 0
  : "${dir:=$folder}"

  name="$(echo "" | $rofi_cmd 'Enter a name')" || exit 0
  : "${name:=$(date +%F_%H-%M-%S)}"

  setsid -f "$TERMINAL" -e nvim "$dir$name.md" >/dev/null 2>&1
}

selected () {
  choice=$(
    {
      echo "New"
      find "$folder" -type f -printf '%T@ %P\n' \
        | sort -nr \
        | cut -d' ' -f2-
    } | $rofi_cmd "Notes"
  )

  case "$choice" in
      New) newnote ;;
      *.md) setsid -f "$TERMINAL" -e nvim "$folder$choice" >/dev/null 2>&1 ;;
      *.pdf|*.png|*.jpg|*.jpeg|*.gif) setsid -f xdg-open "$folder$choice" >/dev/null 2>&1 ;;
      #*) setsid -f xdg-open "$folder$choice" >/dev/null 2>&1 ;;
      *) exit ;;
  esac
}

selected
